{
  "name": "pagepilot-user-frontend",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test:preview-sandbox": "node scripts/previewSandbox.test.mjs",
    "test:template-reuse": "node scripts/templateReuse.test.mjs",
    "test:deploy-errors": "node scripts/deployErrorFriendly.test.mjs",
    "test:deploy-protocol": "node scripts/deployProtocol.test.mjs",
    "test:market-card-layout": "node scripts/marketCardLayout.test.mjs",
    "test:market-performance": "node scripts/marketPerformance.test.mjs",
    "test:market-detail-layout": "node scripts/marketDetailLayout.test.mjs",
    "test:page-background": "node scripts/pageBackground.test.mjs",
    "test:agents-layout": "node scripts/agentsLayout.test.mjs",
    "test:screens-layout": "node scripts/screensLayout.test.mjs",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^6.5.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
